# Mapbox: create a free account at https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_public_access_token_here

# --- Firebase & Google: use JSON files in project root (no .env newline issues) ---
# Place these files in project root (do not commit):
#   - news-map-backend-firebase-adminsdk-fbsvc-bed1474760.json (Firebase Admin)
#   - news-map-backend-4bb197b7f796.json (BigQuery / GDELT)
# Optional overrides for deployment (e.g. when you can't upload files):
#   FIREBASE_CREDENTIALS_PATH=/path/to/firebase.json
#   FIREBASE_CREDENTIALS_BASE64=<base64 of Firebase JSON>
#   GOOGLE_APPLICATION_CREDENTIALS=/path/to/bigquery.json
#   BIGQUERY_CREDENTIALS_BASE64=<base64 of BigQuery JSON>

# Gemini (AI summaries): https://aistudio.google.com/apikey
# Option A: env (no newlines)
GEMINI_API_KEY=your_gemini_api_key_here
# Option B: copy gemini-api-key.json.example to gemini-api-key.json and put key there
# Option C (deployment): GEMINI_API_KEY_BASE64=<base64 of your API key>

# Firecrawl (scraping): https://firecrawl.dev
FIRECRAWL_API_KEY=fc-your-api-key-here
