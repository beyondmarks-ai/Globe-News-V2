# Mapbox: create a free account at https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_public_access_token_here

# --- Firebase & Google (Hostinger / deployment: use literal \n for newlines in keys) ---
# Recommended: store private key as one line with \n for line breaks. Code does: .replace(/\\n/g, "\n")
# Firebase:
#   FIREBASE_PROJECT_ID=news-map-backend
#   FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@news-map-backend.iam.gserviceaccount.com
#   FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# BigQuery:
#   GOOGLE_CLOUD_PROJECT_ID=news-map-backend
#   GOOGLE_CLIENT_EMAIL=gdelt-reader@news-map-backend.iam.gserviceaccount.com
#   GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# Local alternative: place JSON files in project root (do not commit).

# Gemini (AI summaries): https://aistudio.google.com/apikey
# Option A: env (no newlines)
GEMINI_API_KEY=your_gemini_api_key_here
# Option B: copy gemini-api-key.json.example to gemini-api-key.json and put key there
# Option C (deployment): GEMINI_API_KEY_BASE64=<base64 of your API key>

# Firecrawl (scraping): https://firecrawl.dev
FIRECRAWL_API_KEY=fc-your-api-key-here
