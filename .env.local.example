# Mapbox: create a free account at https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_public_access_token_here

# --- Firebase & Google (Hostinger: use BASE64 so you never paste the private key) ---
# On Hostinger set ONLY these two – paste the base64 string (one line, no line breaks):
#   FIREBASE_CREDENTIALS_BASE64=<base64 of your Firebase service account .json file>
#   BIGQUERY_CREDENTIALS_BASE64=<base64 of your BigQuery/GDELT service account .json file>
# To get base64 locally (PowerShell): [Convert]::ToBase64String([IO.File]::ReadAllBytes("path\to\file.json"))
# Or Node: node -e "console.log(require('fs').readFileSync('path/to/file.json').toString('base64'))"
# Other options: FIREBASE_CREDENTIALS_PATH / BIGQUERY_CREDENTIALS_PATH (path to uploaded JSON), or JSON env vars.
# Local: place JSON files in project root (do not commit).

# Gemini (AI summaries): https://aistudio.google.com/apikey
# Option A: env (no newlines)
GEMINI_API_KEY=your_gemini_api_key_here
# Option B: copy gemini-api-key.json.example to gemini-api-key.json and put key there
# Option C (deployment): GEMINI_API_KEY_BASE64=<base64 of your API key>

# Firecrawl (scraping): https://firecrawl.dev
FIRECRAWL_API_KEY=fc-your-api-key-here
